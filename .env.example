# Database
DATABASE_URL="postgresql://user:password@localhost:5432/go_out_already?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Encryption key for refresh tokens (32-byte hex string)
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# Alert email (Gmail with App Password)
ALERT_EMAIL_FROM="your-gmail@gmail.com"
ALERT_EMAIL_APP_PASSWORD="your-gmail-app-password"

# Crawler auth token
CRAWLER_SECRET="generate-a-random-secret"
