generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String   @id @default(uuid())
  googleId               String   @unique
  email                  String   @unique
  name                   String?
  image                  String?
  refreshToken           String?
  defaultRadiusMiles     Int      @default(25)
  defaultReminderMinutes Int      @default(1440)
  alertEmail             String?
  createdAt              DateTime @default(now())

  // Discovery preferences
  homeZipCode         String?
  homeLat             Float?
  homeLng             Float?
  recencyBias         String   @default("moderate") // "all" | "moderate" | "soon"
  blockWorkHours      Boolean  @default(false)
  workStartHour       Int      @default(9)
  workEndHour         Int      @default(17)
  blockLateWeeknights Boolean  @default(false)
  weeknightCutoffHour Int      @default(21)
  weekendsOnly        Boolean  @default(false)
  boostFreeEvents     Boolean  @default(false)
  maxWeeksAhead       Int      @default(8)
  favoriteKeywords    String[]
  blockedKeywords     String[]

  swipeActions        SwipeAction[]
  tagPreferences      UserTagPreference[]
  sourcePreferences   UserSourcePreference[]
  friendshipsAsUser   Friendship[] @relation("UserFriendships")
  friendshipsAsFriend Friendship[] @relation("FriendFriendships")
}

model Event {
  id                String   @id @default(uuid())
  title             String
  description       String?
  date              DateTime @db.Date
  startTime         String?
  endTime           String?
  locationName      String
  address           String?
  lat               Float?
  lng               Float?
  sourceUrl         String
  sourceName        String
  additionalSources Json?
  tags              String[]
  fingerprintHash   String   @unique
  relevanceScore    Float    @default(0)
  crawledAt         DateTime @default(now())
  addedToCalendar   Boolean  @default(false)
  calendarEventId   String?
  archived          Boolean  @default(false)

  swipeActions SwipeAction[]
}

model CrawlLog {
  id             String    @id @default(uuid())
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  sourcesTotal   Int       @default(0)
  sourcesSuccess Int       @default(0)
  eventsFound    Int       @default(0)
  eventsNew      Int       @default(0)
  errors         Json?
  success        Boolean   @default(false)
}

// ── Swipe Mode ──────────────────────────────────────────────────────────────────

// Records every swipe decision a user makes on an event.
// direction: "right" (interested) | "left" (archived/passed)
// @@unique ensures a user can only have one active decision per event (re-swipe overwrites).
model SwipeAction {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  direction String   // "right" | "left"
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@index([userId, direction])
}

// Per-user learned weight for each event tag.
// Updated via EMA after every swipe. Drives the swipe queue ordering.
model UserTagPreference {
  id         String   @id @default(uuid())
  userId     String
  tag        String
  weight     Float    @default(0)
  swipeCount Int      @default(0)
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tag])
  @@index([userId])
}

// Bidirectional friend connections. When A adds B, two rows are created:
// (A→B) and (B→A). Querying WHERE userId = X returns all of X's friends.
model Friendship {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  user   User @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
}

// Per-user learned weight for each event source (team, venue, org name).
// Supplements tag weights for queue scoring.
model UserSourcePreference {
  id         String   @id @default(uuid())
  userId     String
  sourceName String
  weight     Float    @default(0)
  swipeCount Int      @default(0)
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceName])
  @@index([userId])
}
